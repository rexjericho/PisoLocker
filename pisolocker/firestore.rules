rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to read/write their own user document
    match /user/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Lockers collection
    match /lockers/{lockerId} {
      // Allow authenticated users to read all lockers
      allow read: if request.auth != null;
      
      // Allow authenticated users to create lockers (for initialization)
      allow create: if request.auth != null;
      
      // Allow authenticated users to update a locker if:
      // 1. The locker is currently "Available" (anyone can rent it)
      // OR
      // 2. The user is the one who rented it (rentedBy == uid) - for extending/releasing
      allow update: if request.auth != null && 
                    (resource.data.status == 'Available' || resource.data.rentedBy == request.auth.uid);
      
      // Prevent deletion
      allow delete: if false;
    }
  }
}
